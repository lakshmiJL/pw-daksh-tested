rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to read vendor profiles for search & browsing
    match /users/{userId} {
      allow read: if true; 
      // Only the user themselves can edit their profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Menu items are readable by anyone, writable by the vendor
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && 
                   request.resource.data.vendorId == request.auth.uid;
    }
    
    // Orders
    match /orders/{orderId} {
      // User can read their own orders. Vendor can read orders placed with them.
      allow read: if request.auth != null && 
                  (resource.data.userId == request.auth.uid || 
                   resource.data.vendorId == request.auth.uid);
                   
      // Anyone logged in can create an order
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
                    
      // Vendor or customer can update order (e.g. status changes, ratings)
      allow update: if request.auth != null && 
                    (resource.data.userId == request.auth.uid || 
                     resource.data.vendorId == request.auth.uid);
                     
      allow delete: if false; // Never delete orders, keep history
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            resource.data.userId == request.auth.uid;
    }
    
    // Default lockdown for anything not explicitly matched above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
